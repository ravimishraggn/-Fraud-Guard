# Database
DATABASE_URL=postgresql://fraudguard:fraudguard_local@localhost:5432/fraudguard

# Redis
REDIS_URL=redis://localhost:6379/0

# MinIO (local) / S3 (production)
STORAGE_TYPE=minio
MINIO_URL=http://localhost:9000
MINIO_ACCESS_KEY=fraudguard
MINIO_SECRET_KEY=fraudguard_local
MINIO_BUCKET=fraudguard-documents

# OpenAI
OPENAI_API_KEY=sk-...

# JWT
JWT_SECRET=change_this_to_random_64_char_string_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# GSTIN Verification (optional for MVP)
GSTIN_API_KEY=
GSTIN_API_URL=https://api.sandbox.co.in/gsp/assets/resolve-gstin-details

# Email Notifications (optional for MVP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@fraudguard.in

# App
ENVIRONMENT=development
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:3000
